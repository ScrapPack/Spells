# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# TextMeshPro generated files
[Aa]ssets/TextMesh*Pro/Resources/Fonts & Materials/*.asset

# Plastic SCM (Ignore.conf)
.plastic/
.plastic*

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/

# Stale root-level folders (not part of Unity project)
/Assets/
/.claude/
